# Example MySQL environment for Laravel
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

# If you run Laravel outside Docker on the same host, set DB_HOST=127.0.0.1
# and keep the DB_PORT mapping in docker-compose.mysql.yml (3306:3306).

# Remember to copy values into your Laravel project's `.env` file.
